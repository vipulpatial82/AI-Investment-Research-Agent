# Required: Google Gemini key used by `lib/agent.js`.
GOOGLE_API_KEY=your-google-api-key-here

# Optional model override (default: gemini-2.0-flash).
GOOGLE_MODEL=gemini-2.0-flash

# Optional but strongly recommended — live web search for news & competitive
# research (https://tavily.com, free tier available). Without this, the
# agent still runs but falls back to the LLM's own (possibly stale) knowledge
# and clearly labels the output as degraded.
TAVILY_API_KEY=tvly-...

# Optional reliability tuning for slower LLM responses.
# Defaults: timeout=45000ms, retries=2 (total attempts=3).
LLM_TIMEOUT_MS=45000
LLM_MAX_RETRIES=2

# No key needed: market data (price, P/E, market cap, 52w range) is fetched
# from Yahoo Finance's public quote endpoints in lib/tools/stockData.js.
